APP_NAME=coachos-athlete-service
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/coachos_athlete
JWT_SECRET_KEY=replace-with-the-shared-auth-service-secret
JWT_ALGORITHM=HS256
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
INTERNAL_API_PREFIX=/internal/v1
INTERNAL_SERVICE_TOKENS={"media-service":"replace-media-token","ai-review-service":"replace-ai-token"}
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
GRADUATION_YEAR_MIN=2020
GRADUATION_YEAR_MAX=2045
AI_REVIEW_SERVICE_URL=http://host.docker.internal:8004
AI_REVIEW_SERVICE_INTERNAL_URL=http://host.docker.internal:8004
MEDIA_SERVICE_INTERNAL_URL=http://host.docker.internal:8003
UPSTREAM_TIMEOUT_SECONDS=5
MAX_DRILL_TITLE_CHARACTERS=200
MAX_DRILL_DESCRIPTION_CHARACTERS=5000
MAX_DRILL_INSTRUCTIONS_CHARACTERS=10000
MAX_COACH_NOTES_CHARACTERS=10000
MAX_DRILL_TAGS=30
MAX_DRILL_EQUIPMENT_ITEMS=30
DEFAULT_DRILL_ASSIGNMENT_PAGE_SIZE=20
AUTH_SERVICE_INTERNAL_URL=http://localhost:8001
INTERNAL_SERVICE_NAME=athlete-service
INTERNAL_SERVICE_TOKEN=replace-with-athlete-service-token
ATHLETE_DASHBOARD_RECENT_ITEMS_LIMIT=5
ATHLETE_ACCOUNT_LINK_REQUIRED=true
MAX_ATHLETE_NOTE_CHARACTERS=3000
INSIGHT_DEFAULT_RANGE_DAYS=30
INSIGHT_MAX_RANGE_DAYS=365
INSIGHT_TREND_MIN_SAMPLE_SIZE=3
INSIGHT_TREND_THRESHOLD_PERCENTAGE_POINTS=10
INSIGHT_RECURRING_AREA_MIN_REVIEWS=2
INSIGHT_LOW_ACTIVITY_DAYS=14
INSIGHT_INCOMPLETE_ASSIGNMENT_THRESHOLD=5
INSIGHT_REPEATED_AREA_REVIEW_THRESHOLD=3
INSIGHT_REPEATED_AREA_WINDOW_DAYS=60
INSIGHT_GOAL_DUE_SOON_DAYS=14
INSIGHT_NO_FEEDBACK_DAYS=30
INSIGHT_UPSTREAM_TIMEOUT_SECONDS=5
INSIGHT_MAX_BATCH_ATHLETES=100
